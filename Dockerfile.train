# ── OpenEnv: Split-Brain Collapse — GPU Training Space ────────────────────────
# This Dockerfile runs the GRPO curriculum training script.
# Deploy as a separate HF Space with GPU hardware (A10G Small recommended).
#
# Env variables to set in Space Secrets:
#   HF_TOKEN     — your HF write token (to push adapter + plots)
#   HF_USERNAME  — your HF username (default: soonvalley04)
# ──────────────────────────────────────────────────────────────────────────────

FROM python:3.10-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl gcc g++ build-essential \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install PyTorch from the official CUDA 12.1 wheel index (safest for HF Spaces A10G)
# We do not pin versions so pip can cleanly resolve PyTorch 2.6.0 + Torchvision 0.21.0
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir \
    "torch==2.10.0" \
    "torchvision==0.25.0" \
    "torchaudio==2.5.1" \
    --index-url https://download.pytorch.org/whl/cu121

# Install Unsloth and other dependencies in a single block without strict pins
# so pip can perfectly align xformers, torchao, and trl with PyTorch 2.6.0.
RUN pip install --no-cache-dir \
    "unsloth @ git+https://github.com/unslothai/unsloth.git" \
    unsloth_zoo \
    trl \
    datasets \
    matplotlib \
    pydantic \
    networkx \
    python-dotenv \
    huggingface_hub \
    openai \
    bitsandbytes \
    xformers

# Copy repo source
COPY . .

# Create output directories
RUN mkdir -p plots openenv_outputs openenv-split-brain-lora

# Run the curriculum training script
CMD ["python", "train_unsloth_colab.py"]

# ── OpenEnv: Split-Brain Collapse — GPU Training Space ────────────────────────
# This Dockerfile runs the GRPO curriculum training script.
# Deploy as a separate HF Space with GPU hardware (A10G Small recommended).
#
# Env variables to set in Space Secrets:
#   HF_TOKEN     — your HF write token (to push adapter + plots)
#   HF_USERNAME  — your HF username (default: soonvalley04)
# ──────────────────────────────────────────────────────────────────────────────

FROM python:3.10-slim

WORKDIR /app

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    git curl gcc g++ build-essential \
    && apt-get clean && rm -rf /var/lib/apt/lists/*

# Install PyTorch from the official CUDA 12.1 wheel index to avoid any Conda conflicts
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cu121

# Install Unsloth and other dependencies
RUN pip install --no-cache-dir \
        "unsloth @ git+https://github.com/unslothai/unsloth.git" \
        unsloth_zoo \
        trl \
        datasets \
        matplotlib \
        pydantic \
        networkx \
        python-dotenv \
        huggingface_hub \
        openai \
        xformers \
        bitsandbytes

# Copy repo source
COPY . .

# Create output directories
RUN mkdir -p plots openenv_outputs openenv-split-brain-lora

# Run the curriculum training script
CMD ["python", "train_unsloth_colab.py"]
